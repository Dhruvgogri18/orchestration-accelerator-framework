# --- Internal LLM Gateway (OpenAI-compatible) ---
# Copy this file to .env and fill in real values. NEVER commit .env.
GATEWAY_API_KEY=gdtc_user_c66ecfd94c13d05f576e485d68c4eb12
GATEWAY_BASE_URL=https://aigateway-api.godigitaltc.com/aigw/v1
GATEWAY_CHAT_MODEL=codex/gpt-5.6-sol
GATEWAY_EMBEDDING_MODEL=           # TODO: confirm - see "Embeddings" note in scripts/test_gateway_connection.py

# --- AWS ---
AWS_REGION=us-east-1
AWS_PROFILE=                       # optional, if using named profiles instead of env creds
STEP_FUNCTIONS_EXECUTION_ROLE_ARN=  # IAM role Step Functions will assume at deploy time

# --- Repository ingestion ---
REPO_PATH=.                        # path to the repo the assistant should index
INCLUDE_GLOBS=**/*.py,**/*.yaml,**/*.yml,**/*.json,**/*.md
EXCLUDE_GLOBS=**/.venv/**,**/node_modules/**,**/.git/**

# --- Vector store ---
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=repo_context

# --- Chunking ---
CHUNK_SIZE_TOKENS=800
CHUNK_OVERLAP_TOKENS=120